CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE=example.com
CF_RECORD=home.example.com
CF_RECORD_TYPE=A
CF_TTL=1
CF_PROXIED=false
CF_CREATE=true
CF_DRY_RUN=false

# Gateway used to detect the public IP before updating Cloudflare.
GATEWAY=192.168.1.1
GATEWAY_INTERFACE=eth0

# Optional IP detection and policy-routing settings.
IP_CHECK_URL=
IP_CHECK_TIMEOUT=15
ROUTE_MARK=0x66
ROUTE_TABLE=50001
ROUTE_PRIORITY=10000
ROUTE_ONLINK=true
