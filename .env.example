CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE=example.com
CF_RECORD=home.example.com
CF_RECORD_TYPE=A
CF_TTL=1
CF_PROXIED=false
CF_CREATE=true
CF_DRY_RUN=false

# Optional gateway override used for policy-routing based IP detection.
# Leave these empty to use the host default network path when detecting the public IP.
GATEWAY=
GATEWAY_INTERFACE=

# Optional IP detection and policy-routing settings.
IP_CHECK_URL=
IP_CHECK_TIMEOUT=15
ROUTE_MARK=0x66
ROUTE_TABLE=50001
ROUTE_PRIORITY=10000
ROUTE_ONLINK=true
